<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:ma="clr-namespace:Maui.Assemblage;assembly=Maui.Assemblage"
             xmlns:local="clr-namespace:Maui.Assemblage.Sample"
             x:Class="Maui.Assemblage.Sample.RichTemplateStressPage"
             Title="Rich Template Stress" SafeAreaEdges="None">

    <ContentPage.Resources>

        <DataTemplate x:Key="ArticleTemplate" x:DataType="local:RichStressItem">
            <Border Margin="12,6" Padding="0" StrokeThickness="1"
                    Stroke="{AppThemeBinding Light=#E4E4E7, Dark=#3A3A3C}"
                    BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#1C1C1E}">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="18"/>
                </Border.StrokeShape>
                <Grid ColumnDefinitions="6,*">
                    <BoxView Color="{Binding AccentColor}"/>
                    <VerticalStackLayout Grid.Column="1" Padding="14,12" Spacing="8">
                        <Grid ColumnDefinitions="*,Auto">
                            <Label Text="{Binding Title}" FontSize="17" FontAttributes="Bold" MaxLines="2"/>
                            <Border Grid.Column="1" Padding="8,3" StrokeThickness="0" BackgroundColor="{Binding SoftAccentColor}">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="10"/>
                                </Border.StrokeShape>
                                <Label Text="{Binding KindLabel}" FontSize="11" TextColor="{Binding AccentColor}"/>
                            </Border>
                        </Grid>
                        <Label Text="{Binding Body}" FontSize="13" LineBreakMode="WordWrap" MaxLines="4"/>
                        <FlexLayout Wrap="Wrap" Direction="Row" AlignItems="Start" JustifyContent="Start">
                            <Border Padding="8,4" Margin="0,0,6,4" StrokeThickness="0" BackgroundColor="{AppThemeBinding Light=#F4F4F5, Dark=#2C2C2E}">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="10"/>
                                </Border.StrokeShape>
                                <Label Text="{Binding Meta1}" FontSize="11"/>
                            </Border>
                            <Border Padding="8,4" Margin="0,0,6,4" StrokeThickness="0" BackgroundColor="{AppThemeBinding Light=#F4F4F5, Dark=#2C2C2E}">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="10"/>
                                </Border.StrokeShape>
                                <Label Text="{Binding Meta2}" FontSize="11"/>
                            </Border>
                            <Border Padding="8,4" Margin="0,0,6,4" StrokeThickness="0" BackgroundColor="{AppThemeBinding Light=#F4F4F5, Dark=#2C2C2E}">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="10"/>
                                </Border.StrokeShape>
                                <Label Text="{Binding Meta3}" FontSize="11"/>
                            </Border>
                        </FlexLayout>
                        <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="8">
                            <Label Text="{Binding HeightLabel}" FontSize="11" TextColor="#8E8E93" VerticalTextAlignment="Center"/>
                            <Button Grid.Column="1" Text="Read" FontSize="11" HeightRequest="32" Padding="12,0" Clicked="OnItemButtonClicked"/>
                            <Button Grid.Column="2" Text="Save" FontSize="11" HeightRequest="32" Padding="12,0" Clicked="OnItemButtonClicked"/>
                        </Grid>
                    </VerticalStackLayout>
                </Grid>
            </Border>
        </DataTemplate>

        <DataTemplate x:Key="HeroTemplate" x:DataType="local:RichStressItem">
            <Border Margin="12,6" Padding="0" StrokeThickness="1"
                    Stroke="{AppThemeBinding Light=#E4E4E7, Dark=#3A3A3C}"
                    BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#1C1C1E}">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="22"/>
                </Border.StrokeShape>
                <VerticalStackLayout Spacing="0">
                    <Grid HeightRequest="168" BackgroundColor="{Binding AccentColor}">
                        <Label Text="{Binding Icon}" FontSize="58" HorizontalOptions="Center" VerticalOptions="Center"/>
                        <Border Padding="8,4" Margin="12" StrokeThickness="0"
                                BackgroundColor="#99000000"
                                HorizontalOptions="Start" VerticalOptions="End">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="10"/>
                            </Border.StrokeShape>
                            <Label Text="{Binding Meta1}" FontSize="12" TextColor="White"/>
                        </Border>
                    </Grid>
                    <VerticalStackLayout Padding="14,12" Spacing="8">
                        <Label Text="{Binding Title}" FontSize="18" FontAttributes="Bold" MaxLines="2"/>
                        <Label Text="{Binding Body}" FontSize="13" LineBreakMode="WordWrap" MaxLines="3"/>
                        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10">
                            <ProgressBar Progress="{Binding Progress1}" ProgressColor="{Binding AccentColor}" VerticalOptions="Center"/>
                            <Label Grid.Column="1" Text="{Binding Progress1Text}" FontSize="12" TextColor="{Binding AccentColor}" FontAttributes="Bold"/>
                        </Grid>
                        <Label Text="{Binding HeightLabel}" FontSize="11" TextColor="#8E8E93"/>
                    </VerticalStackLayout>
                </VerticalStackLayout>
            </Border>
        </DataTemplate>

        <DataTemplate x:Key="MetricTemplate" x:DataType="local:RichStressItem">
            <Border Margin="12,6" Padding="14,12" StrokeThickness="1"
                    Stroke="{AppThemeBinding Light=#E4E4E7, Dark=#3A3A3C}"
                    BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#1C1C1E}">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="18"/>
                </Border.StrokeShape>
                <VerticalStackLayout Spacing="10">
                    <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12">
                        <Border WidthRequest="44" HeightRequest="44" StrokeThickness="0" BackgroundColor="{Binding SoftAccentColor}">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="22"/>
                            </Border.StrokeShape>
                            <Label Text="{Binding Icon}" FontSize="22" HorizontalTextAlignment="Center" VerticalTextAlignment="Center"/>
                        </Border>
                        <VerticalStackLayout Grid.Column="1" Spacing="2" VerticalOptions="Center">
                            <Label Text="{Binding Title}" FontSize="16" FontAttributes="Bold"/>
                            <Label Text="{Binding Body}" FontSize="12" TextColor="#8E8E93" MaxLines="2"/>
                        </VerticalStackLayout>
                        <Label Grid.Column="2" Text="{Binding Value}" FontSize="22" FontAttributes="Bold" TextColor="{Binding AccentColor}" VerticalTextAlignment="Center"/>
                    </Grid>
                    <VerticalStackLayout Spacing="7">
                        <Grid ColumnDefinitions="82,*" ColumnSpacing="10">
                            <Label Text="{Binding Metric1}" FontSize="12" TextColor="#8E8E93"/>
                            <ProgressBar Grid.Column="1" Progress="{Binding Progress1}" ProgressColor="{Binding AccentColor}"/>
                        </Grid>
                        <Grid ColumnDefinitions="82,*" ColumnSpacing="10">
                            <Label Text="{Binding Metric2}" FontSize="12" TextColor="#8E8E93"/>
                            <ProgressBar Grid.Column="1" Progress="{Binding Progress2}" ProgressColor="{Binding AccentColor}"/>
                        </Grid>
                        <Grid ColumnDefinitions="82,*" ColumnSpacing="10">
                            <Label Text="{Binding Metric3}" FontSize="12" TextColor="#8E8E93"/>
                            <ProgressBar Grid.Column="1" Progress="{Binding Progress3}" ProgressColor="{Binding AccentColor}"/>
                        </Grid>
                    </VerticalStackLayout>
                    <Slider Value="{Binding SliderValue, Mode=OneWay}" Minimum="0" Maximum="100" ValueChanged="OnItemSliderChanged"/>
                    <Label Text="{Binding HeightLabel}" FontSize="11" TextColor="#8E8E93"/>
                </VerticalStackLayout>
            </Border>
        </DataTemplate>

        <DataTemplate x:Key="ChecklistTemplate" x:DataType="local:RichStressItem">
            <Border Margin="12,6" Padding="14,12" StrokeThickness="1"
                    Stroke="{AppThemeBinding Light=#E4E4E7, Dark=#3A3A3C}"
                    BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#1C1C1E}">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="18"/>
                </Border.StrokeShape>
                <VerticalStackLayout Spacing="10">
                    <Grid ColumnDefinitions="*,Auto">
                        <VerticalStackLayout Spacing="2">
                            <Label Text="{Binding Title}" FontSize="16" FontAttributes="Bold"/>
                            <Label Text="{Binding Body}" FontSize="12" TextColor="#8E8E93" MaxLines="2"/>
                        </VerticalStackLayout>
                        <Border Grid.Column="1" Padding="8,4" StrokeThickness="0" BackgroundColor="{Binding SoftAccentColor}" VerticalOptions="Start">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="10"/>
                            </Border.StrokeShape>
                            <Label Text="{Binding Value}" FontSize="12" TextColor="{Binding AccentColor}" FontAttributes="Bold"/>
                        </Border>
                    </Grid>
                    <VerticalStackLayout Spacing="4">
                        <Grid ColumnDefinitions="Auto,*" ColumnSpacing="8">
                            <CheckBox IsChecked="{Binding Flag1, Mode=OneWay}" CheckedChanged="OnItemCheckedChanged"/>
                            <Label Grid.Column="1" Text="{Binding Detail1}" FontSize="13" VerticalTextAlignment="Center"/>
                        </Grid>
                        <Grid ColumnDefinitions="Auto,*" ColumnSpacing="8">
                            <CheckBox IsChecked="{Binding Flag2, Mode=OneWay}" CheckedChanged="OnItemCheckedChanged"/>
                            <Label Grid.Column="1" Text="{Binding Detail2}" FontSize="13" VerticalTextAlignment="Center"/>
                        </Grid>
                        <Grid ColumnDefinitions="Auto,*" ColumnSpacing="8">
                            <CheckBox IsChecked="{Binding Flag3, Mode=OneWay}" CheckedChanged="OnItemCheckedChanged"/>
                            <Label Grid.Column="1" Text="{Binding Detail3}" FontSize="13" VerticalTextAlignment="Center"/>
                        </Grid>
                    </VerticalStackLayout>
                    <Grid ColumnDefinitions="*,Auto">
                        <ProgressBar Progress="{Binding Progress1}" ProgressColor="{Binding AccentColor}" VerticalOptions="Center"/>
                        <Label Grid.Column="1" Text="{Binding HeightLabel}" FontSize="11" TextColor="#8E8E93"/>
                    </Grid>
                </VerticalStackLayout>
            </Border>
        </DataTemplate>

        <DataTemplate x:Key="EventTemplate" x:DataType="local:RichStressItem">
            <Border Margin="12,6" Padding="14,12" StrokeThickness="1"
                    Stroke="{AppThemeBinding Light=#E4E4E7, Dark=#3A3A3C}"
                    BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#1C1C1E}">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="18"/>
                </Border.StrokeShape>
                <Grid ColumnDefinitions="76,*" ColumnSpacing="14">
                    <Border BackgroundColor="{Binding SoftAccentColor}" StrokeThickness="0" VerticalOptions="Start" HeightRequest="88">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="16"/>
                        </Border.StrokeShape>
                        <VerticalStackLayout Spacing="0" VerticalOptions="Center">
                            <Label Text="{Binding Meta1}" FontSize="12" TextColor="{Binding AccentColor}" FontAttributes="Bold" HorizontalTextAlignment="Center"/>
                            <Label Text="{Binding Value}" FontSize="26" TextColor="{Binding AccentColor}" FontAttributes="Bold" HorizontalTextAlignment="Center"/>
                        </VerticalStackLayout>
                    </Border>
                    <VerticalStackLayout Grid.Column="1" Spacing="8">
                        <Label Text="{Binding Title}" FontSize="17" FontAttributes="Bold" MaxLines="2"/>
                        <Label Text="{Binding Body}" FontSize="13" LineBreakMode="WordWrap" MaxLines="3"/>
                        <Grid ColumnDefinitions="Auto,*" ColumnSpacing="8">
                            <Label Text="📍" FontSize="14"/>
                            <Label Grid.Column="1" Text="{Binding Detail1}" FontSize="12" TextColor="#8E8E93" MaxLines="1"/>
                        </Grid>
                        <Grid ColumnDefinitions="Auto,*" ColumnSpacing="8">
                            <Label Text="👥" FontSize="14"/>
                            <Label Grid.Column="1" Text="{Binding Detail2}" FontSize="12" TextColor="#8E8E93" MaxLines="1"/>
                        </Grid>
                        <Grid ColumnDefinitions="*,Auto">
                            <Label Text="{Binding HeightLabel}" FontSize="11" TextColor="#8E8E93" VerticalTextAlignment="Center"/>
                            <Button Grid.Column="1" Text="Join" FontSize="11" HeightRequest="32" Padding="12,0" Clicked="OnItemButtonClicked"/>
                        </Grid>
                    </VerticalStackLayout>
                </Grid>
            </Border>
        </DataTemplate>

        <DataTemplate x:Key="ProfileTemplate" x:DataType="local:RichStressItem">
            <Border Margin="12,6" Padding="14,12" StrokeThickness="1"
                    Stroke="{AppThemeBinding Light=#E4E4E7, Dark=#3A3A3C}"
                    BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#1C1C1E}">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="18"/>
                </Border.StrokeShape>
                <VerticalStackLayout Spacing="10">
                    <Grid ColumnDefinitions="64,*,Auto" ColumnSpacing="12">
                        <Border WidthRequest="56" HeightRequest="56" StrokeThickness="0" BackgroundColor="{Binding AccentColor}">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="28"/>
                            </Border.StrokeShape>
                            <Label Text="{Binding Initials}" FontSize="18" FontAttributes="Bold" TextColor="White" HorizontalTextAlignment="Center" VerticalTextAlignment="Center"/>
                        </Border>
                        <VerticalStackLayout Grid.Column="1" Spacing="2" VerticalOptions="Center">
                            <Label Text="{Binding Title}" FontSize="17" FontAttributes="Bold"/>
                            <Label Text="{Binding Meta1}" FontSize="12" TextColor="#8E8E93"/>
                        </VerticalStackLayout>
                        <Switch Grid.Column="2" IsToggled="{Binding Flag1, Mode=OneWay}" Toggled="OnItemToggled" VerticalOptions="Center"/>
                    </Grid>
                    <Label Text="{Binding Body}" FontSize="13" LineBreakMode="WordWrap" MaxLines="3"/>
                    <Grid ColumnDefinitions="*,*,*" ColumnSpacing="8">
                        <Border Padding="8" StrokeThickness="0" BackgroundColor="{AppThemeBinding Light=#F4F4F5, Dark=#2C2C2E}">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="12"/>
                            </Border.StrokeShape>
                            <VerticalStackLayout Spacing="2">
                                <Label Text="{Binding Metric1}" FontSize="11" TextColor="#8E8E93"/>
                                <Label Text="{Binding Detail1}" FontSize="13" FontAttributes="Bold"/>
                            </VerticalStackLayout>
                        </Border>
                        <Border Grid.Column="1" Padding="8" StrokeThickness="0" BackgroundColor="{AppThemeBinding Light=#F4F4F5, Dark=#2C2C2E}">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="12"/>
                            </Border.StrokeShape>
                            <VerticalStackLayout Spacing="2">
                                <Label Text="{Binding Metric2}" FontSize="11" TextColor="#8E8E93"/>
                                <Label Text="{Binding Detail2}" FontSize="13" FontAttributes="Bold"/>
                            </VerticalStackLayout>
                        </Border>
                        <Border Grid.Column="2" Padding="8" StrokeThickness="0" BackgroundColor="{AppThemeBinding Light=#F4F4F5, Dark=#2C2C2E}">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="12"/>
                            </Border.StrokeShape>
                            <VerticalStackLayout Spacing="2">
                                <Label Text="{Binding Metric3}" FontSize="11" TextColor="#8E8E93"/>
                                <Label Text="{Binding Detail3}" FontSize="13" FontAttributes="Bold"/>
                            </VerticalStackLayout>
                        </Border>
                    </Grid>
                    <Label Text="{Binding HeightLabel}" FontSize="11" TextColor="#8E8E93"/>
                </VerticalStackLayout>
            </Border>
        </DataTemplate>

        <DataTemplate x:Key="ReviewTemplate" x:DataType="local:RichStressItem">
            <Border Margin="12,6" Padding="14,12" StrokeThickness="1"
                    Stroke="{AppThemeBinding Light=#E4E4E7, Dark=#3A3A3C}"
                    BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#1C1C1E}">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="18"/>
                </Border.StrokeShape>
                <VerticalStackLayout Spacing="9">
                    <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="10">
                        <Label Text="{Binding Icon}" FontSize="24" VerticalTextAlignment="Center"/>
                        <VerticalStackLayout Grid.Column="1" Spacing="2">
                            <Label Text="{Binding Title}" FontSize="16" FontAttributes="Bold"/>
                            <Label Text="{Binding Meta1}" FontSize="12" TextColor="#8E8E93"/>
                        </VerticalStackLayout>
                        <Border Grid.Column="2" Padding="8,4" StrokeThickness="0" BackgroundColor="{Binding SoftAccentColor}" VerticalOptions="Center">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="10"/>
                            </Border.StrokeShape>
                            <Label Text="{Binding Value}" FontSize="12" TextColor="{Binding AccentColor}" FontAttributes="Bold"/>
                        </Border>
                    </Grid>
                    <Border Padding="10,8" StrokeThickness="0" BackgroundColor="{AppThemeBinding Light=#18181B, Dark=#09090B}">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="12"/>
                        </Border.StrokeShape>
                        <VerticalStackLayout Spacing="3">
                            <Label Text="{Binding Detail1}" FontSize="12" TextColor="#A7F3D0" FontFamily="monospace"/>
                            <Label Text="{Binding Detail2}" FontSize="12" TextColor="#FCA5A5" FontFamily="monospace"/>
                            <Label Text="{Binding Detail3}" FontSize="12" TextColor="#93C5FD" FontFamily="monospace"/>
                        </VerticalStackLayout>
                    </Border>
                    <Label Text="{Binding Body}" FontSize="13" LineBreakMode="WordWrap" MaxLines="3"/>
                    <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="8">
                        <Label Text="{Binding HeightLabel}" FontSize="11" TextColor="#8E8E93" VerticalTextAlignment="Center"/>
                        <Button Grid.Column="1" Text="Approve" FontSize="11" HeightRequest="32" Padding="12,0" Clicked="OnItemButtonClicked"/>
                        <Button Grid.Column="2" Text="Fix" FontSize="11" HeightRequest="32" Padding="12,0" Clicked="OnItemButtonClicked"/>
                    </Grid>
                </VerticalStackLayout>
            </Border>
        </DataTemplate>

        <DataTemplate x:Key="AlertTemplate" x:DataType="local:RichStressItem">
            <Border Margin="12,6" Padding="14,12" StrokeThickness="1"
                    Stroke="{Binding AccentColor}"
                    BackgroundColor="{Binding SoftAccentColor}">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="18"/>
                </Border.StrokeShape>
                <Grid ColumnDefinitions="Auto,*" ColumnSpacing="12">
                    <Border WidthRequest="44" HeightRequest="44" StrokeThickness="0" BackgroundColor="{Binding AccentColor}" VerticalOptions="Start">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="22"/>
                        </Border.StrokeShape>
                        <Label Text="{Binding Icon}" FontSize="22" HorizontalTextAlignment="Center" VerticalTextAlignment="Center"/>
                    </Border>
                    <VerticalStackLayout Grid.Column="1" Spacing="8">
                        <Grid ColumnDefinitions="*,Auto">
                            <Label Text="{Binding Title}" FontSize="16" FontAttributes="Bold" MaxLines="2"/>
                            <Label Grid.Column="1" Text="{Binding Value}" FontSize="12" TextColor="{Binding AccentColor}" FontAttributes="Bold"/>
                        </Grid>
                        <Label Text="{Binding Body}" FontSize="13" LineBreakMode="WordWrap" MaxLines="4"/>
                        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10">
                            <ProgressBar Progress="{Binding Progress1}" ProgressColor="{Binding AccentColor}" VerticalOptions="Center"/>
                            <Switch Grid.Column="1" IsToggled="{Binding Flag2, Mode=OneWay}" Toggled="OnItemToggled"/>
                        </Grid>
                        <Label Text="{Binding HeightLabel}" FontSize="11" TextColor="#8E8E93"/>
                    </VerticalStackLayout>
                </Grid>
            </Border>
        </DataTemplate>

        <local:RichStressTemplateSelector x:Key="RichStressSelector"
                                          ArticleTemplate="{StaticResource ArticleTemplate}"
                                          HeroTemplate="{StaticResource HeroTemplate}"
                                          MetricTemplate="{StaticResource MetricTemplate}"
                                          ChecklistTemplate="{StaticResource ChecklistTemplate}"
                                          EventTemplate="{StaticResource EventTemplate}"
                                          ProfileTemplate="{StaticResource ProfileTemplate}"
                                          ReviewTemplate="{StaticResource ReviewTemplate}"
                                          AlertTemplate="{StaticResource AlertTemplate}"/>

    </ContentPage.Resources>

    <Grid RowDefinitions="Auto,Auto,*" Padding="0" RowSpacing="0" SafeAreaEdges="None"
          BackgroundColor="{AppThemeBinding Light=#F4F4F5, Dark=#000000}">

        <Grid Padding="16,10" ColumnDefinitions="*,Auto"
              BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#1C1C1E}">
            <VerticalStackLayout Spacing="2">
                <Label Text="Rich Template Stress" FontSize="20" FontAttributes="Bold"/>
                <Label Text="8 templates · variable heights · generated data" FontSize="12" TextColor="#8E8E93"/>
            </VerticalStackLayout>
            <Label Grid.Column="1" x:Name="StatusLabel" FontSize="12" TextColor="#8E8E93"
                   VerticalOptions="Center" HorizontalTextAlignment="End"/>
        </Grid>

        <ScrollView Grid.Row="1" Orientation="Horizontal" HorizontalScrollBarVisibility="Never"
                    BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#1C1C1E}">
            <HorizontalStackLayout Padding="16,8" Spacing="8">
                <Button Text="1,000" FontSize="12" HeightRequest="34" Padding="12,0" Clicked="OnLoad1K"/>
                <Button Text="5,000" FontSize="12" HeightRequest="34" Padding="12,0" Clicked="OnLoad5K"/>
                <Button Text="20,000" FontSize="12" HeightRequest="34" Padding="12,0" Clicked="OnLoad20K"/>
                <BoxView WidthRequest="1" HeightRequest="28" Color="{AppThemeBinding Light=#E4E4E7, Dark=#3A3A3C}" Margin="6,0"/>
                <Button Text="Top" FontSize="12" HeightRequest="34" Padding="12,0" Clicked="OnScrollTop"/>
                <Button Text="Middle" FontSize="12" HeightRequest="34" Padding="12,0" Clicked="OnScrollMiddle"/>
                <Button Text="End" FontSize="12" HeightRequest="34" Padding="12,0" Clicked="OnScrollEnd"/>
            </HorizontalStackLayout>
        </ScrollView>

        <ma:ListHostView Grid.Row="2"
                         x:Name="RichList"
                         AutomationId="RichTemplateStressList"
                         ItemExtent="240"
                         Spacing="0"
                         ItemTemplateSelector="{StaticResource RichStressSelector}"
                         UseMeasuredItemExtents="True"
                         Orientation="Vertical"/>

    </Grid>

</ContentPage>
