<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:ma="clr-namespace:Maui.Assemblage;assembly=Maui.Assemblage"
             x:Class="Maui.Assemblage.Sample.StaggeredGridPage"
             Title="Staggered" SafeAreaEdges="None">

    <Grid RowDefinitions="Auto,*" Padding="16" RowSpacing="8" SafeAreaEdges="None">

        <Label AutomationId="StaggeredTitle"
               Text="Staggered Grid (Pinterest-Style)"
               FontSize="22" FontAttributes="Bold"
               HorizontalOptions="Center" />

        <ma:StaggeredGridHostView Grid.Row="1"
                                   x:Name="StaggeredGrid"
                                   AutomationId="StaggeredGrid"
                                   Margin="-16,0,-16,-16"
                                   ContentInset="16,0,16,16"
                                   SpanCount="2"
                                   DefaultItemHeight="100"
                                   HorizontalSpacing="8"
                                   VerticalSpacing="8">

            <ma:StaggeredGridHostView.ItemTemplate>
                <DataTemplate>
                    <Border BackgroundColor="{Binding Color}"
                            StrokeShape="RoundRectangle 8"
                            Stroke="{AppThemeBinding Light=#E0E0E0, Dark=#444444}"
                            StrokeThickness="1"
                            Padding="12">
                        <VerticalStackLayout VerticalOptions="Center" HorizontalOptions="Center" Spacing="4">
                            <Label Text="{Binding Title}"
                                   FontSize="14" FontAttributes="Bold"
                                   TextColor="White"
                                   HorizontalTextAlignment="Center" />
                            <Label Text="{Binding Subtitle}"
                                   FontSize="11"
                                   TextColor="#DDDDDD"
                                   HorizontalTextAlignment="Center" />
                        </VerticalStackLayout>
                    </Border>
                </DataTemplate>
            </ma:StaggeredGridHostView.ItemTemplate>

        </ma:StaggeredGridHostView>

    </Grid>

</ContentPage>
