<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:ma="clr-namespace:Maui.Assemblage;assembly=Maui.Assemblage"
             x:Class="Maui.Assemblage.Sample.SpanningHeaderGridPage"
             Title="GridGrouped" SafeAreaEdges="None">

    <Grid RowDefinitions="Auto,*" Padding="16" RowSpacing="8" SafeAreaEdges="None">

        <Label AutomationId="SpanningTitle"
               Text="Grid with Spanning Headers"
               FontSize="22" FontAttributes="Bold"
               HorizontalOptions="Center" />

        <ma:CollectionHostView Grid.Row="1"
                                x:Name="SpanningGrid"
                                AutomationId="SpanningGrid"
                                Margin="-16,0,-16,-16"
                                ContentInset="16,0,16,16">

            <ma:CollectionHostView.SectionHeaderTemplate>
                <DataTemplate>
                    <Border BackgroundColor="{AppThemeBinding Light=#6750A4, Dark=#D0BCFF}"
                            StrokeThickness="0"
                            Padding="16,8">
                        <Label Text="{Binding .}"
                               FontSize="17" FontAttributes="Bold"
                               TextColor="{AppThemeBinding Light=White, Dark=#1C1B1F}" />
                    </Border>
                </DataTemplate>
            </ma:CollectionHostView.SectionHeaderTemplate>

            <ma:CollectionHostView.ItemTemplate>
                <DataTemplate>
                    <Border BackgroundColor="{AppThemeBinding Light=#F5F0FF, Dark=#2A2A2A}"
                            StrokeShape="RoundRectangle 6"
                            Stroke="{AppThemeBinding Light=#E0E0E0, Dark=#444444}"
                            StrokeThickness="1"
                            Padding="8">
                        <Label Text="{Binding .}"
                               FontSize="13"
                               VerticalTextAlignment="Center"
                               HorizontalTextAlignment="Center" />
                    </Border>
                </DataTemplate>
            </ma:CollectionHostView.ItemTemplate>

        </ma:CollectionHostView>

    </Grid>

</ContentPage>
