<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:ma="clr-namespace:Maui.Assemblage;assembly=Maui.Assemblage"
             x:Class="Maui.Assemblage.Sample.TimelinePage"
             Title="Timeline" SafeAreaEdges="None">

    <Grid RowDefinitions="Auto,*" Padding="0" RowSpacing="0"
          BackgroundColor="{AppThemeBinding Light=#F8F9FA, Dark=#121212}" SafeAreaEdges="None">

        <Label AutomationId="TimelineTitle"
               Text="Project Timeline"
               FontSize="22" FontAttributes="Bold"
               HorizontalOptions="Center"
               Margin="0,12,0,8" />

        <ma:TimelineHostView Grid.Row="1"
                              x:Name="TimelineList"
                              AutomationId="TimelineList"
                              ItemHeight="90"
                              Spacing="8"
                              SpineWidth="3">

            <ma:TimelineHostView.ItemTemplate>
                <DataTemplate>
                    <Border BackgroundColor="{Binding Color}"
                            StrokeShape="RoundRectangle 12"
                            StrokeThickness="0"
                            Padding="12">
                        <Grid RowDefinitions="Auto,Auto,Auto" RowSpacing="4">
                            <Label Text="{Binding Date}"
                                   FontSize="10"
                                   TextColor="#99FFFFFF"
                                   FontAttributes="Bold" />
                            <Label Grid.Row="1"
                                   Text="{Binding Title}"
                                   FontSize="14"
                                   FontAttributes="Bold"
                                   TextColor="White"
                                   MaxLines="1"
                                   LineBreakMode="TailTruncation" />
                            <Label Grid.Row="2"
                                   Text="{Binding Description}"
                                   FontSize="11"
                                   TextColor="#CCFFFFFF"
                                   MaxLines="2"
                                   LineBreakMode="TailTruncation" />
                        </Grid>
                    </Border>
                </DataTemplate>
            </ma:TimelineHostView.ItemTemplate>

        </ma:TimelineHostView>

    </Grid>

</ContentPage>
