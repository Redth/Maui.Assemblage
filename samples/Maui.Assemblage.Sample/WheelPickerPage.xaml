<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:ma="clr-namespace:Maui.Assemblage;assembly=Maui.Assemblage"
             x:Class="Maui.Assemblage.Sample.WheelPickerPage"
             Title="Wheel Picker" SafeAreaEdges="None">

    <Grid RowDefinitions="Auto,Auto,Auto,*" Padding="16" RowSpacing="12"
          BackgroundColor="{AppThemeBinding Light=#F0F0F5, Dark=#1A1A2E}" SafeAreaEdges="None">

        <Label AutomationId="WheelTitle"
               Text="Wheel Picker"
               FontSize="22" FontAttributes="Bold"
               HorizontalOptions="Center" />

        <Label Grid.Row="1"
               Text="Select a country"
               FontSize="14"
               HorizontalOptions="Center"
               TextColor="{AppThemeBinding Light=#666, Dark=#AAA}" />

        <!-- Wheel picker container -->
        <Grid Grid.Row="2" HorizontalOptions="Center"
              WidthRequest="320" HeightRequest="340"
              IsClippedToBounds="True">

            <!-- Top/bottom fade overlays -->
            <BoxView BackgroundColor="{AppThemeBinding Light=#F0F0F5, Dark=#1A1A2E}"
                     Opacity="0.6"
                     HeightRequest="40"
                     VerticalOptions="Start"
                     InputTransparent="True"
                     ZIndex="10" />
            <BoxView BackgroundColor="{AppThemeBinding Light=#F0F0F5, Dark=#1A1A2E}"
                     Opacity="0.6"
                     HeightRequest="40"
                     VerticalOptions="End"
                     InputTransparent="True"
                     ZIndex="10" />

            <!-- Selection highlight band -->
            <Border BackgroundColor="{AppThemeBinding Light=#DDDDF0, Dark=#2A2A4A}"
                    StrokeShape="RoundRectangle 12"
                    Stroke="{AppThemeBinding Light=#C0C0D0, Dark=#3A3A5A}"
                    StrokeThickness="1"
                    HeightRequest="48"
                    VerticalOptions="Center"
                    InputTransparent="True"
                    ZIndex="2" />

            <ma:WheelHostView x:Name="WheelView"
                               AutomationId="WheelView"
                               ItemHeight="48"
                               MaxRotation="60"
                               MinScale="0.65"
                               MinOpacity="0.2"
                               HeightRequest="340"
                               ZIndex="3">

                <ma:WheelHostView.ItemTemplate>
                    <DataTemplate>
                        <Grid Padding="16,0">
                            <HorizontalStackLayout HorizontalOptions="Center"
                                                    VerticalOptions="Center"
                                                    Spacing="12">
                                <Label Text="{Binding Flag}"
                                       FontSize="24"
                                       VerticalTextAlignment="Center" />
                                <Label Text="{Binding Name}"
                                       FontSize="18"
                                       FontAttributes="Bold"
                                       TextColor="{AppThemeBinding Light=#222, Dark=#EEE}"
                                       VerticalTextAlignment="Center" />
                                <Label Text="{Binding Code}"
                                       FontSize="13"
                                       TextColor="{AppThemeBinding Light=#888, Dark=#888}"
                                       VerticalTextAlignment="Center" />
                            </HorizontalStackLayout>
                        </Grid>
                    </DataTemplate>
                </ma:WheelHostView.ItemTemplate>

            </ma:WheelHostView>

        </Grid>

        <!-- Selected country display -->
        <Border Grid.Row="3" 
                Margin="0,8,0,0"
                Padding="20"
                BackgroundColor="{AppThemeBinding Light=White, Dark=#252540}"
                StrokeShape="RoundRectangle 16"
                Stroke="{AppThemeBinding Light=#E0E0E0, Dark=#3A3A5A}"
                StrokeThickness="1"
                VerticalOptions="Start"
                HorizontalOptions="Center"
                WidthRequest="320">
            <VerticalStackLayout Spacing="4" HorizontalOptions="Center">
                <Label x:Name="SelectedFlag"
                       AutomationId="SelectedFlag"
                       Text="🇺🇸"
                       FontSize="40"
                       HorizontalOptions="Center" />
                <Label x:Name="SelectedLabel"
                       AutomationId="SelectedLabel"
                       Text="United States"
                       FontSize="20" FontAttributes="Bold"
                       HorizontalOptions="Center"
                       TextColor="{AppThemeBinding Light=#222, Dark=#EEE}" />
                <Label x:Name="SelectedCode"
                       AutomationId="SelectedCode"
                       Text="+1"
                       FontSize="14"
                       HorizontalOptions="Center"
                       TextColor="{AppThemeBinding Light=#666, Dark=#AAA}" />
            </VerticalStackLayout>
        </Border>

    </Grid>

</ContentPage>
