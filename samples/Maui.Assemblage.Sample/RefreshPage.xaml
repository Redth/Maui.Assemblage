<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:ma="clr-namespace:Maui.Assemblage;assembly=Maui.Assemblage"
             x:Class="Maui.Assemblage.Sample.RefreshPage"
             Title="Refresh" SafeAreaEdges="None">

    <Grid RowDefinitions="Auto,Auto,*" Padding="16" RowSpacing="8" SafeAreaEdges="None">

        <Label AutomationId="RefreshTitle"
               Text="Pull-to-Refresh Demo"
               FontSize="22" FontAttributes="Bold"
               HorizontalOptions="Center" />

        <HorizontalStackLayout Grid.Row="1" Spacing="8" HorizontalOptions="Center">
            <Label x:Name="RefreshInfo" AutomationId="RefreshInfo" Text="0 items · Pull or tap Refresh" VerticalOptions="Center" />
            <Button AutomationId="RefreshBtn" Text="Refresh" Clicked="OnRefreshBtnClicked" />
        </HorizontalStackLayout>

        <ma:ListHostView Grid.Row="2"
                         x:Name="RefreshList"
                         AutomationId="RefreshList"
                         Margin="-16,0,-16,-16"
                         ContentInset="16,0,16,16"
                         ItemExtent="52"
                         Spacing="4"
                         IsRefreshEnabled="True"
                         EmptyView="Pull down to load items">

            <ma:ListHostView.ItemTemplate>
                <DataTemplate>
                    <Border BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#2A2A2A}"
                            StrokeShape="RoundRectangle 8"
                            Stroke="{AppThemeBinding Light=#E0E0E0, Dark=#444444}"
                            StrokeThickness="1"
                            Padding="12,8">
                        <HorizontalStackLayout Spacing="8">
                            <Label Text="🔄" FontSize="16" VerticalTextAlignment="Center" />
                            <Label Text="{Binding .}"
                                   FontSize="16"
                                   VerticalTextAlignment="Center" />
                        </HorizontalStackLayout>
                    </Border>
                </DataTemplate>
            </ma:ListHostView.ItemTemplate>

            <ma:ListHostView.EmptyViewTemplate>
                <DataTemplate>
                    <Grid>
                        <VerticalStackLayout VerticalOptions="Center" HorizontalOptions="Center" Spacing="8">
                            <Label Text="⬇️" FontSize="48" HorizontalTextAlignment="Center" />
                            <Label Text="{Binding .}" FontSize="18" TextColor="Gray" HorizontalTextAlignment="Center" />
                        </VerticalStackLayout>
                    </Grid>
                </DataTemplate>
            </ma:ListHostView.EmptyViewTemplate>

        </ma:ListHostView>

    </Grid>

</ContentPage>
